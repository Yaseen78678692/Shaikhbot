<!DOCTYPE html>
<html lang="en" class="antialiased">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Universal AI Chat</title>
    
    <!-- 1. STYLES & ICONS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css">

    <!-- 2. TAILWIND CONFIG -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        gemini: {
                            bg: '#ffffff',
                            darkBg: '#131314',
                            surface: '#f0f4f9',
                            darkSurface: '#1e1f20',
                            primary: '#0b57d0',
                            darkPrimary: '#a8c7fa'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    animation: {
                        'pulse-fast': 'pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>

    <!-- 3. CUSTOM CSS -->
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');
        
        /* Core Layout - Mobile Viewport Fix */
        body { 
            height: 100dvh; 
            overflow: hidden; 
            background-color: #ffffff; 
            color: #1f2937; 
            transition: background-color 0.3s, color 0.3s;
        }
        .dark body { 
            background-color: #131314; 
            color: #e3e3e3; 
        }

        /* Custom Scrollbars */
        .scrollbar-custom::-webkit-scrollbar { width: 6px; height: 6px; }
        .scrollbar-custom::-webkit-scrollbar-track { background: transparent; }
        .scrollbar-custom::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 10px; }
        .dark .scrollbar-custom::-webkit-scrollbar-thumb { background: #444746; }
        .scrollbar-custom:hover::-webkit-scrollbar-thumb { background: #d1d5db; }
        .dark .scrollbar-custom:hover::-webkit-scrollbar-thumb { background: #5e5e5e; }

        /* Markdown Content Styling */
        .prose { max-width: none; font-size: 0.95rem; line-height: 1.6; }
        .prose pre { background: #1e1f20 !important; border-radius: 0.75rem; border: 1px solid #444746; margin: 0.75rem 0; }
        .prose code { font-family: 'JetBrains Mono', monospace; font-size: 0.85em; background: rgba(135, 131, 120, 0.15); padding: 0.2em 0.4em; border-radius: 4px; color: #d93025; }
        .dark .prose code { color: #e2b93d; background: rgba(255, 255, 255, 0.1); }
        .prose pre code { background: transparent; color: inherit; padding: 0; }
        .prose p { margin-bottom: 0.75rem; }
        .prose ul { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 0.75rem; }
        .prose ol { list-style-type: decimal; padding-left: 1.5rem; margin-bottom: 0.75rem; }
        .prose strong { font-weight: 600; color: inherit; }
        .prose a { color: #0b57d0; text-decoration: none; }
        .dark .prose a { color: #a8c7fa; }
        .prose h1, .prose h2, .prose h3 { font-weight: 600; margin-top: 1rem; margin-bottom: 0.5rem; color: inherit; }

        /* Loading Screen */
        #loading-overlay {
            position: fixed; inset: 0; z-index: 9999;
            background: #ffffff; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
        }
        .dark #loading-overlay { background: #131314; color: white; }
        
        /* Sidebar Transition */
        #sidebar { transition: transform 0.3s ease-in-out; }
        @media (max-width: 768px) {
            #sidebar { position: absolute; height: 100%; z-index: 40; transform: translateX(-100%); box-shadow: 4px 0 24px rgba(0,0,0,0.2); }
            #sidebar.open { transform: translateX(0); }
            #overlay-backdrop { display: none; }
            #overlay-backdrop.active { display: block; position: absolute; inset: 0; background: rgba(0,0,0,0.5); z-index: 30; }
        }
    </style>
</head>
<body class="flex text-sm md:text-base">

    <!-- LOADER -->
    <div id="loading-overlay">
        <div class="w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin mb-4"></div>
        <div class="text-lg font-medium animate-pulse">Initializing Core...</div>
    </div>

    <!-- MOBILE BACKDROP -->
    <div id="overlay-backdrop" onclick="App.toggleSidebar()"></div>

    <!-- SIDEBAR -->
    <aside id="sidebar" class="w-[280px] bg-gray-50 dark:bg-[#1e1f20] flex flex-col border-r border-gray-200 dark:border-[#444746] shrink-0 md:relative h-full">
        <!-- Header -->
        <div class="p-4 pt-6">
            <button onclick="App.toggleSidebar()" class="md:hidden mb-4 p-2 hover:bg-gray-200 dark:hover:bg-[#333537] rounded-full">
                <i data-lucide="arrow-left" class="w-5 h-5"></i>
            </button>
            
            <button onclick="App.newChat()" class="w-full flex items-center gap-3 px-4 py-3 bg-[#dde3ea] dark:bg-[#282a2c] hover:bg-[#d1d9e0] dark:hover:bg-[#333537] transition-colors rounded-xl text-sm font-medium text-gemini-primary dark:text-gemini-darkPrimary">
                <i data-lucide="plus" class="w-4 h-4"></i>
                <span>New Chat</span>
            </button>
        </div>

        <!-- History -->
        <div class="px-3 pb-2 text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Recent</div>
        <div id="chat-history-list" class="flex-1 overflow-y-auto scrollbar-custom px-2 space-y-1 pb-4">
            <!-- Chat Items Injected Here -->
        </div>

        <!-- Footer -->
        <div class="p-3 border-t border-gray-200 dark:border-[#444746]">
            <button onclick="App.toggleSettings()" class="flex w-full items-center gap-3 px-3 py-2.5 hover:bg-gray-200 dark:hover:bg-[#333537] rounded-lg transition-colors text-sm">
                <i data-lucide="settings" class="w-4 h-4"></i>
                <span>Settings</span>
            </button>
            <button onclick="App.toggleTheme()" class="flex w-full items-center gap-3 px-3 py-2.5 hover:bg-gray-200 dark:hover:bg-[#333537] rounded-lg transition-colors text-sm">
                <i data-lucide="moon" id="theme-icon" class="w-4 h-4"></i>
                <span id="theme-label">Dark Mode</span>
            </button>
        </div>
    </aside>

    <!-- MAIN AREA -->
    <main class="flex-1 flex flex-col h-full relative min-w-0 bg-gemini-bg dark:bg-gemini-darkBg">
        <!-- Top Bar -->
        <header class="h-16 flex items-center justify-between px-4 shrink-0">
            <div class="flex items-center gap-3">
                <button onclick="App.toggleSidebar()" class="p-2 hover:bg-gray-100 dark:hover:bg-[#333537] rounded-full text-gray-600 dark:text-gray-300 md:hidden">
                    <i data-lucide="menu" class="w-5 h-5"></i>
                </button>
                <div class="flex flex-col cursor-pointer" onclick="App.toggleSettings()">
                    <span class="text-sm font-semibold flex items-center gap-1 text-gray-700 dark:text-gray-200">
                        Universal AI <i data-lucide="chevron-down" class="w-3 h-3 opacity-50"></i>
                    </span>
                    <span id="header-model-name" class="text-[10px] text-gray-500 dark:text-gray-400 font-mono">Loading...</span>
                </div>
            </div>
            <div class="flex gap-1">
                 <button onclick="App.deleteCurrentChat()" class="p-2 hover:bg-red-50 dark:hover:bg-red-900/20 text-red-500 rounded-full" title="Delete Chat">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                </button>
            </div>
        </header>

        <!-- Messages Area -->
        <div id="messages-container" class="flex-1 overflow-y-auto scrollbar-custom p-4 space-y-6 pb-8">
            <!-- Welcome State -->
            <div id="welcome-screen" class="h-full flex flex-col items-center justify-center text-center opacity-0 transition-opacity duration-500">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center mb-6 shadow-lg shadow-blue-500/20">
                    <i data-lucide="sparkles" class="w-8 h-8 text-white"></i>
                </div>
                <h1 class="text-2xl md:text-3xl font-semibold bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400 mb-2">
                    Hello, Human
                </h1>
                <p class="text-gray-500 dark:text-gray-400 max-w-md text-sm md:text-base">
                    I'm ready to help. Configure your API key in settings to start chatting with OpenRouter models.
                </p>
            </div>
        </div>

        <!-- Input Area -->
        <div class="shrink-0 p-4 bg-gemini-bg dark:bg-gemini-darkBg">
            <div class="max-w-4xl mx-auto relative">
                <div class="bg-gemini-surface dark:bg-gemini-darkSurface rounded-[28px] p-2 pl-4 pr-2 flex items-end gap-2 transition-all focus-within:ring-2 ring-blue-500/20 dark:ring-blue-400/20">
                    <textarea 
                        id="prompt-input"
                        rows="1"
                        placeholder="Ask anything..."
                        class="w-full bg-transparent border-none outline-none resize-none py-3 max-h-32 overflow-y-auto scrollbar-custom text-base text-gray-800 dark:text-gray-100 placeholder-gray-500"
                        oninput="this.style.height='auto'; this.style.height=this.scrollHeight+'px'"
                        onkeydown="if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); App.sendMessage(); }"
                    ></textarea>
                    <button id="send-btn" onclick="App.sendMessage()" disabled class="p-3 bg-blue-600 text-white rounded-full hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-blue-600 transition-all mb-0.5 shadow-md">
                        <i data-lucide="send-horizontal" class="w-5 h-5"></i>
                    </button>
                </div>
                <div class="text-center mt-2">
                    <p class="text-[10px] text-gray-400 dark:text-gray-500">
                        AI may display inaccurate info. Double-check responses.
                    </p>
                </div>
            </div>
        </div>
    </main>

    <!-- SETTINGS MODAL -->
    <dialog id="settings-modal" class="bg-transparent p-0 w-full h-full backdrop:bg-black/50 z-50 open:flex items-center justify-center hidden">
        <div class="bg-white dark:bg-[#1e1f20] w-[90%] max-w-md rounded-2xl shadow-2xl border border-gray-200 dark:border-[#444746] overflow-hidden animate-[fade-in_0.2s_ease-out]">
            <div class="p-4 border-b border-gray-200 dark:border-[#444746] flex justify-between items-center">
                <h3 class="font-semibold text-gray-900 dark:text-white">Settings</h3>
                <button onclick="App.toggleSettings()" class="p-1 hover:bg-gray-100 dark:hover:bg-[#333537] rounded-full"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6 space-y-5">
                
                <div>
                    <label class="block text-xs font-bold uppercase text-gray-500 mb-1.5">OpenRouter API Key</label>
                    <div class="relative">
                        <input type="password" id="set-key" placeholder="sk-or-v1-..." class="w-full bg-gray-50 dark:bg-[#131314] border border-gray-300 dark:border-[#444746] rounded-lg px-3 py-2.5 text-sm outline-none focus:border-blue-500 transition-colors">
                        <i data-lucide="key" class="w-4 h-4 absolute right-3 top-3 text-gray-400"></i>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-gray-500 mb-1.5">Model Slug</label>
                    <input type="text" id="set-model" value="deepseek/deepseek-r1:free" class="w-full bg-gray-50 dark:bg-[#131314] border border-gray-300 dark:border-[#444746] rounded-lg px-3 py-2.5 text-sm outline-none focus:border-blue-500 transition-colors">
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase text-gray-500 mb-1.5">System Prompt</label>
                    <textarea id="set-system" rows="3" class="w-full bg-gray-50 dark:bg-[#131314] border border-gray-300 dark:border-[#444746] rounded-lg px-3 py-2.5 text-sm outline-none focus:border-blue-500 transition-colors resize-none"></textarea>
                </div>

            </div>
            <div class="p-4 bg-gray-50 dark:bg-[#282a2c] flex justify-end gap-3">
                <button onclick="App.toggleSettings()" class="px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-[#333537] rounded-lg transition-colors">Cancel</button>
                <button onclick="App.saveSettings()" class="px-4 py-2 text-sm font-medium bg-blue-600 text-white rounded-lg hover:bg-blue-700 shadow-lg shadow-blue-600/20 transition-all">Save Changes</button>
            </div>
        </div>
    </dialog>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        /**
         * UNIVERSAL AI CHAT LOGIC
         * Architecture: State -> UI Render -> Persistence
         */
        const App = {
            state: {
                chats: [],
                activeChatId: null,
                settings: {
                    apiKey: '',
                    model: 'deepseek/deepseek-r1:free',
                    systemPrompt: 'You are a helpful, expert AI assistant. Use Markdown for formatting.',
                    theme: 'light'
                },
                isGenerating: false
            },

            elements: {},

            init() {
                // Cache DOM elements
                this.elements = {
                    loading: document.getElementById('loading-overlay'),
                    messagesContainer: document.getElementById('messages-container'),
                    input: document.getElementById('prompt-input'),
                    sendBtn: document.getElementById('send-btn'),
                    historyList: document.getElementById('chat-history-list'),
                    settingsModal: document.getElementById('settings-modal'),
                    welcomeScreen: document.getElementById('welcome-screen'),
                    headerModel: document.getElementById('header-model-name'),
                    sidebar: document.getElementById('sidebar'),
                    backdrop: document.getElementById('overlay-backdrop')
                };

                // Load Data
                this.loadStorage();
                this.applyTheme();
                this.renderHistory();

                // Setup Hooks
                this.elements.input.addEventListener('input', () => this.toggleSendBtn());
                
                // Route
                if (this.state.chats.length > 0) {
                    this.loadChat(this.state.chats[0].id);
                } else {
                    this.newChat(false);
                }

                // Config Markdown
                marked.setOptions({
                    highlight: (code, lang) => {
                        const language = highlight.getLanguage(lang) ? lang : 'plaintext';
                        return highlight.highlight(code, { language }).value;
                    },
                    breaks: true,
                    gfm: true
                });

                // Hide Loader
                setTimeout(() => {
                    this.elements.loading.style.opacity = '0';
                    setTimeout(() => this.elements.loading.remove(), 300);
                    this.elements.welcomeScreen.style.opacity = '1';
                }, 500);

                // Init Icons
                lucide.createIcons();
            },

            /* --- STATE MANAGEMENT --- */
            loadStorage() {
                const s = localStorage.getItem('uai_settings');
                const c = localStorage.getItem('uai_chats');
                if (s) this.state.settings = { ...this.state.settings, ...JSON.parse(s) };
                if (c) this.state.chats = JSON.parse(c);
                
                // Update Inputs
                document.getElementById('set-key').value = this.state.settings.apiKey;
                document.getElementById('set-model').value = this.state.settings.model;
                document.getElementById('set-system').value = this.state.settings.systemPrompt;
                this.elements.headerModel.innerText = this.state.settings.model;
            },

            saveStorage() {
                localStorage.setItem('uai_settings', JSON.stringify(this.state.settings));
                localStorage.setItem('uai_chats', JSON.stringify(this.state.chats));
            },

            /* --- CHAT OPERATIONS --- */
            newChat(render = true) {
                if (this.state.isGenerating) return;
                const id = Date.now().toString();
                const chat = { id, title: 'New Conversation', messages: [], timestamp: Date.now() };
                this.state.chats.unshift(chat);
                this.saveStorage();
                if (render) {
                    this.renderHistory();
                    this.loadChat(id);
                    if(window.innerWidth < 768) this.toggleSidebar();
                }
            },

            loadChat(id) {
                this.state.activeChatId = id;
                this.renderHistory(); // To update active state styling
                this.renderMessages();
                this.elements.input.focus();
            },

            deleteCurrentChat() {
                if(!confirm("Delete this conversation?")) return;
                this.state.chats = this.state.chats.filter(c => c.id !== this.state.activeChatId);
                this.saveStorage();
                if(this.state.chats.length > 0) {
                    this.loadChat(this.state.chats[0].id);
                } else {
                    this.newChat();
                }
            },

            async sendMessage() {
                if (this.state.isGenerating) return;
                const text = this.elements.input.value.trim();
                if (!text) return;

                // Check API Key
                if (!this.state.settings.apiKey) {
                    alert('Please set your OpenRouter API Key in Settings first.');
                    this.toggleSettings();
                    return;
                }

                // UI Reset
                this.elements.input.value = '';
                this.elements.input.style.height = 'auto';
                this.toggleSendBtn();
                
                // User Message
                this.addMessage('user', text);

                // AI Placeholder
                this.state.isGenerating = true;
                const aiMsgId = this.addMessage('assistant', ''); // Empty initially

                // Stream Logic
                const currentChat = this.state.chats.find(c => c.id === this.state.activeChatId);
                const payload = {
                    model: this.state.settings.model,
                    messages: [
                        { role: 'system', content: this.state.settings.systemPrompt },
                        ...currentChat.messages.slice(0, -1) // Exclude placeholder (not yet in state)
                    ],
                    stream: true
                };
                // Add user msg to payload
                payload.messages.push({ role: 'user', content: text });

                let fullResponse = "";
                const aiBubbleContent = document.getElementById(`msg-content-${aiMsgId}`);

                try {
                    const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                        method: "POST",
                        headers: {
                            "Authorization": `Bearer ${this.state.settings.apiKey}`,
                            "Content-Type": "application/json",
                            "HTTP-Referer": window.location.href,
                            "X-Title": "Universal AI"
                        },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        const err = await response.json();
                        throw new Error(err.error?.message || 'API Connection Failed');
                    }

                    const reader = response.body.getReader();
                    const decoder = new TextDecoder();

                    while (true) {
                        const { done, value } = await reader.read();
                        if (done) break;
                        
                        const chunk = decoder.decode(value, { stream: true });
                        const lines = chunk.split('\n');

                        for (const line of lines) {
                            if (line.startsWith('data: ') && line !== 'data: [DONE]') {
                                try {
                                    const json = JSON.parse(line.replace('data: ', ''));
                                    const content = json.choices[0]?.delta?.content || "";
                                    fullResponse += content;
                                    aiBubbleContent.innerHTML = marked.parse(fullResponse);
                                    this.scrollToBottom();
                                } catch (e) { /* Skip incomplete JSON */ }
                            }
                        }
                    }

                    // Update Chat Title if 1st exchange
                    if(currentChat.messages.length === 1) {
                        currentChat.title = text.substring(0, 30) + (text.length > 30 ? '...' : '');
                        this.renderHistory();
                    }

                    // Save AI Response to State
                    const aiMsgIndex = currentChat.messages.findIndex(m => m.id === aiMsgId); // Wait, we didn't push id to state.
                    // Correction: We update the chat state now
                    currentChat.messages.push({ role: 'assistant', content: fullResponse });
                    this.saveStorage();

                } catch (err) {
                    aiBubbleContent.innerHTML += `<br><span class="text-red-500 font-bold">Error: ${err.message}</span>`;
                    currentChat.messages.push({ role: 'assistant', content: fullResponse + `\n[Error: ${err.message}]` });
                    this.saveStorage();
                } finally {
                    this.state.isGenerating = false;
                    // Syntax Highlight Final Code Blocks
                    aiBubbleContent.querySelectorAll('pre code').forEach(block => highlight.highlightElement(block));
                    lucide.createIcons();
                }
            },

            /* --- RENDERERS --- */
            addMessage(role, content) {
                const chat = this.state.chats.find(c => c.id === this.state.activeChatId);
                if (!chat) return;
                
                // If user, push to state immediately. If AI, we wait for stream to finish (handled in sendMessage)
                // Wait, we need to push user msg to state to render it correctly if we reload.
                if (role === 'user') {
                    chat.messages.push({ role, content });
                    this.saveStorage();
                }

                const msgId = Date.now().toString() + Math.random();
                const html = this.buildMessageHTML(role, content, msgId);
                this.elements.messagesContainer.insertAdjacentHTML('beforeend', html);
                this.scrollToBottom();
                lucide.createIcons();

                // If user, hide welcome
                if (this.elements.messagesContainer.contains(this.elements.welcomeScreen)) {
                    this.elements.welcomeScreen.style.display = 'none';
                }
                
                return msgId;
            },

            renderMessages() {
                const chat = this.state.chats.find(c => c.id === this.state.activeChatId);
                const container = this.elements.messagesContainer;
                
                container.innerHTML = ''; // Clear
                if (!chat || chat.messages.length === 0) {
                    container.appendChild(this.elements.welcomeScreen);
                    this.elements.welcomeScreen.style.display = 'flex';
                    return;
                }

                this.elements.welcomeScreen.style.display = 'none';
                let html = '';
                chat.messages.forEach(msg => {
                    html += this.buildMessageHTML(msg.role, msg.content);
                });
                container.innerHTML = html;
                
                // Highlight existing code
                container.querySelectorAll('pre code').forEach(block => highlight.highlightElement(block));
                this.scrollToBottom();
                lucide.createIcons();
            },

            buildMessageHTML(role, content, id = null) {
                const isUser = role === 'user';
                const align = isUser ? 'flex-row-reverse' : 'flex-row';
                const bubbleStyle = isUser 
                    ? 'bg-[#e7f1ff] dark:bg-[#182b44] rounded-2xl rounded-tr-sm' 
                    : 'rounded-2xl px-0'; // Gemini style: AI messages are flat text basically

                const parsedContent = isUser ? content : marked.parse(content);
                const avatar = isUser 
                    ? `<div class="w-8 h-8 bg-gray-200 dark:bg-[#444746] rounded-full flex items-center justify-center shrink-0 text-gray-600 dark:text-gray-300"><i data-lucide="user" class="w-5 h-5"></i></div>`
                    : `<div class="w-8 h-8 bg-transparent rounded-full flex items-center justify-center shrink-0"><i data-lucide="sparkles" class="w-6 h-6 text-gemini-primary dark:text-gemini-darkPrimary fill-current"></i></div>`;

                return `
                    <div class="flex gap-4 ${align} w-full animate-[slideUp_0.3s_ease-out]">
                        ${avatar}
                        <div class="flex flex-col max-w-[85%] md:max-w-[75%] gap-1">
                            <div class="font-semibold text-xs text-gray-400 ${isUser ? 'text-right' : 'text-left'}">
                                ${isUser ? 'You' : 'Universal AI'}
                            </div>
                            <div id="msg-content-${id}" class="prose dark:prose-invert text-sm md:text-base ${isUser ? 'px-4 py-3' : ''} ${bubbleStyle}">
                                ${parsedContent}
                            </div>
                        </div>
                    </div>
                `;
            },

            renderHistory() {
                const list = this.elements.historyList;
                list.innerHTML = '';
                
                this.state.chats.forEach(chat => {
                    const isActive = chat.id === this.state.activeChatId;
                    const item = document.createElement('div');
                    item.className = `group flex items-center gap-3 p-3 rounded-full cursor-pointer transition-colors text-sm truncate ${isActive ? 'bg-[#c2e7ff] dark:bg-[#004a77] text-[#001d35] dark:text-[#c2e7ff] font-semibold' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-[#333537]'}`;
                    item.onclick = () => this.loadChat(chat.id);
                    item.innerHTML = `
                        <i data-lucide="message-square" class="w-4 h-4 shrink-0 opacity-70"></i>
                        <span class="truncate flex-1">${chat.title}</span>
                    `;
                    list.appendChild(item);
                });
                lucide.createIcons();
            },

            /* --- UTILS --- */
            toggleSidebar() {
                this.elements.sidebar.classList.toggle('open');
                this.elements.backdrop.classList.toggle('active');
            },

            toggleSettings() {
                const m = this.elements.settingsModal;
                m.style.display = (m.style.display === 'flex') ? 'none' : 'flex';
            },

            saveSettings() {
                this.state.settings.apiKey = document.getElementById('set-key').value.trim();
                this.state.settings.model = document.getElementById('set-model').value.trim();
                this.state.settings.systemPrompt = document.getElementById('set-system').value.trim();
                this.elements.headerModel.innerText = this.state.settings.model;
                this.saveStorage();
                this.toggleSettings();
            },

            toggleTheme() {
                const html = document.documentElement;
                const isDark = html.classList.toggle('dark');
                this.state.settings.theme = isDark ? 'dark' : 'light';
                this.updateThemeIcon();
                this.saveStorage();
            },

            applyTheme() {
                const html = document.documentElement;
                if (this.state.settings.theme === 'dark') html.classList.add('dark');
                else html.classList.remove('dark');
                this.updateThemeIcon();
            },

            updateThemeIcon() {
                const isDark = this.state.settings.theme === 'dark';
                const icon = document.getElementById('theme-icon');
                const text = document.getElementById('theme-label');
                icon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
                text.innerText = isDark ? 'Light Mode' : 'Dark Mode';
                lucide.createIcons();
            },

            toggleSendBtn() {
                this.elements.sendBtn.disabled = !this.elements.input.value.trim() || this.state.isGenerating;
            },

            scrollToBottom() {
                const c = this.elements.messagesContainer;
                c.scrollTo({ top: c.scrollHeight, behavior: 'smooth' });
            }
        };

        // BOOTSTRAP
        document.addEventListener('DOMContentLoaded', () => App.init());
    </script>
</body>
</html>
